#!/bin/bash
# transcribe.sh — Transcribe audio/video to markdown using Whisper
# Usage: ./tools/transcribe.sh <input_file> [--model <model>]
# Generated by WikiForge for {{config.project.name}}

set -euo pipefail

INPUT="${1:?Usage: ./tools/transcribe.sh <input_file> [--model <model>]}"
MODEL="${3:-base}"

# Parse optional --model flag
if [[ "${2:-}" == "--model" ]]; then
    MODEL="${3:?Error: --model requires a value (tiny, base, small, medium, large)}"
fi

# Check that whisper is installed
if ! command -v whisper &>/dev/null; then
    echo "Error: whisper is not installed."
    echo "Install it with: pip install openai-whisper"
    exit 1
fi

if ! [ -f "$INPUT" ]; then
    echo "Error: File not found: $INPUT"
    exit 1
fi

# Prepare output directory
mkdir -p raw/transcripts

BASENAME=$(basename "$INPUT" | sed 's/\.[^.]*$//')
OUTPUT_DIR="raw/transcripts"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
CONTENT_HASH=$(shasum -a 256 "$INPUT" | cut -c1-16)

echo "=== Transcribing: $INPUT ==="
echo "Model: $MODEL"
echo ""

# Run whisper
whisper "$INPUT" \
    --model "$MODEL" \
    --output_format txt \
    --output_dir "$OUTPUT_DIR" \
    --language en

# Convert whisper output to markdown with frontmatter
TXT_FILE="$OUTPUT_DIR/$BASENAME.txt"
MD_FILE="$OUTPUT_DIR/$BASENAME.md"

if [ -f "$TXT_FILE" ]; then
    {
        echo "---"
        echo "type: source"
        echo "title: \"$BASENAME\""
        echo "author: \"\""
        echo "date: \"\""
        echo "url: \"\""
        echo "source_type: \"transcript\""
        echo "content_hash: \"$CONTENT_HASH\""
        echo "ingested_at: \"$TIMESTAMP\""
        echo "status: \"raw\""
        echo "---"
        echo ""
        echo "# $BASENAME"
        echo ""
        echo "## Transcript"
        echo ""
        cat "$TXT_FILE"
    } > "$MD_FILE"

    # Clean up the plain text file
    rm "$TXT_FILE"

    echo ""
    echo "Saved to: $MD_FILE"
    echo "Content hash: $CONTENT_HASH"
else
    echo "Error: Whisper did not produce expected output file."
    exit 1
fi

echo ""
echo "=== Transcription complete ==="
