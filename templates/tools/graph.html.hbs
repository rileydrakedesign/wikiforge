<!DOCTYPE html>
<!--
  graph.html — interactive graph of the {{config.project.name}} wiki
  Generated by WikiForge.

  How to use:
    1. Run `./.forge/tools/build-graph.sh` to (re)generate the graph data from
       the current wiki state. That script walks wiki/ for {{config.wiki.cross_ref_style}}
       links and writes graph-data.js next to this file.
    2. Open graph.html in a browser (or serve it: `python3 -m http.server` from
       this directory).

  Click a node to open its page. Hover to highlight neighbors. Drag to reposition.
-->
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{config.project.name}} — wiki graph</title>
  <script src="https://unpkg.com/d3@7/dist/d3.min.js"></script>
  <style>
    html, body { margin: 0; padding: 0; height: 100%; font-family: ui-sans-serif, system-ui, sans-serif; background: #0d1117; color: #c9d1d9; }
    header { padding: 12px 20px; border-bottom: 1px solid #21262d; display: flex; gap: 16px; align-items: baseline; }
    header h1 { margin: 0; font-size: 16px; font-weight: 600; }
    header .meta { color: #8b949e; font-size: 13px; }
    #graph { width: 100%; height: calc(100% - 56px); }
    .node { cursor: pointer; }
    .node text { font-size: 11px; fill: #c9d1d9; pointer-events: none; }
    .node.entity circle { fill: #58a6ff; }
    .node.concept circle { fill: #d2a8ff; }
    .node.source circle { fill: #7ee787; }
    .node.comparison circle { fill: #ffa657; }
    .node.overview circle { fill: #f0883e; }
    .node.stub circle { fill: #6e7681; }
    .node.superseded circle { fill: #6e7681; stroke: #f85149; stroke-width: 1.5; }
    .link { stroke: #30363d; stroke-opacity: 0.7; }
    .node:hover circle { stroke: #f0f6fc; stroke-width: 2; }
    .node.dim { opacity: 0.15; }
    .link.dim { opacity: 0.05; }
    .legend { position: absolute; right: 16px; bottom: 16px; background: rgba(22, 27, 34, 0.85); border: 1px solid #21262d; padding: 10px 12px; border-radius: 6px; font-size: 12px; }
    .legend div { display: flex; align-items: center; gap: 6px; padding: 2px 0; }
    .legend span.swatch { display: inline-block; width: 10px; height: 10px; border-radius: 50%; }
  </style>
</head>
<body>
  <header>
    <h1>{{config.project.name}}</h1>
    <span class="meta">domain: {{config.project.domain}}</span>
    <span class="meta" id="counts"></span>
  </header>
  <div id="graph"></div>
  <div class="legend">
    <div><span class="swatch" style="background:#58a6ff"></span>entity</div>
    <div><span class="swatch" style="background:#d2a8ff"></span>concept</div>
    <div><span class="swatch" style="background:#7ee787"></span>source</div>
    <div><span class="swatch" style="background:#ffa657"></span>comparison</div>
    <div><span class="swatch" style="background:#6e7681"></span>stub / superseded</div>
  </div>

  <script src="graph-data.js"></script>
  <script>
    // graph-data.js exports `GRAPH = { nodes: [...], links: [...] }`.
    // If it hasn't been generated yet, show a hint.
    if (typeof GRAPH === "undefined") {
      document.getElementById("graph").innerHTML =
        '<p style="padding:20px;color:#8b949e">No graph data yet. Run <code>./.forge/tools/build-graph.sh</code> to generate it.</p>';
    } else {
      document.getElementById("counts").textContent =
        GRAPH.nodes.length + " pages, " + GRAPH.links.length + " links";

      const width = window.innerWidth;
      const height = window.innerHeight - 56;
      const svg = d3.select("#graph").append("svg")
        .attr("width", width).attr("height", height);
      const g = svg.append("g");
      svg.call(d3.zoom().on("zoom", e => g.attr("transform", e.transform)));

      const sim = d3.forceSimulation(GRAPH.nodes)
        .force("link", d3.forceLink(GRAPH.links).id(d => d.id).distance(60))
        .force("charge", d3.forceManyBody().strength(-180))
        .force("center", d3.forceCenter(width / 2, height / 2))
        .force("collision", d3.forceCollide(14));

      const link = g.append("g").attr("class", "links")
        .selectAll("line").data(GRAPH.links).join("line").attr("class", "link");

      const node = g.append("g").attr("class", "nodes")
        .selectAll("g").data(GRAPH.nodes).join("g")
        .attr("class", d => "node " + d.type + (d.status === "superseded" ? " superseded" : "") + (d.status === "stub" ? " stub" : ""))
        .call(drag(sim))
        .on("click", (_, d) => { if (d.path) window.location.href = d.path; })
        .on("mouseover", (_, d) => highlight(d, true))
        .on("mouseout", () => highlight(null, false));
      node.append("circle").attr("r", d => 4 + Math.sqrt(d.source_count || 1) * 2);
      node.append("text").attr("dx", 8).attr("dy", 3).text(d => d.title);

      sim.on("tick", () => {
        link.attr("x1", d => d.source.x).attr("y1", d => d.source.y)
            .attr("x2", d => d.target.x).attr("y2", d => d.target.y);
        node.attr("transform", d => "translate(" + d.x + "," + d.y + ")");
      });

      function highlight(focus, on) {
        if (!on || !focus) {
          node.classed("dim", false);
          link.classed("dim", false);
          return;
        }
        const neighbors = new Set([focus.id]);
        GRAPH.links.forEach(l => {
          if (l.source.id === focus.id) neighbors.add(l.target.id);
          if (l.target.id === focus.id) neighbors.add(l.source.id);
        });
        node.classed("dim", d => !neighbors.has(d.id));
        link.classed("dim", l => l.source.id !== focus.id && l.target.id !== focus.id);
      }

      function drag(sim) {
        return d3.drag()
          .on("start", e => { if (!e.active) sim.alphaTarget(0.3).restart(); e.subject.fx = e.subject.x; e.subject.fy = e.subject.y; })
          .on("drag",  e => { e.subject.fx = e.x; e.subject.fy = e.y; })
          .on("end",   e => { if (!e.active) sim.alphaTarget(0); e.subject.fx = null; e.subject.fy = null; });
      }
    }
  </script>
</body>
</html>
