#!/bin/bash
# build-graph.sh — extract nodes and links from the wiki and write graph-data.js
# Pairs with graph.html; run this before viewing the graph.
# Generated by WikiForge for {{config.project.name}}

set -euo pipefail

OUTFILE=".forge/tools/graph-data.js"
WIKI_DIR="wiki"

if ! [ -d "$WIKI_DIR" ]; then
    echo "Error: $WIKI_DIR/ not found. Run from the project root."
    exit 1
fi

if ! command -v python3 &>/dev/null; then
    echo "Error: python3 is required (used for the markdown walk)."
    exit 1
fi

python3 - <<'PY' "$WIKI_DIR" "$OUTFILE"
import json
import os
import re
import sys
from pathlib import Path

wiki_dir = Path(sys.argv[1])
out_path = Path(sys.argv[2])

# Map: page slug -> {id, title, type, path, source_count, status}
nodes = {}
# List of {source, target}
links = []

# Type from directory
def page_type(rel_path):
    parts = rel_path.parts
    if len(parts) < 2:
        return "overview"  # overview.md, index.md, log.md
    return {
        "entities": "entity",
        "concepts": "concept",
        "sources": "source",
        "comparisons": "comparison",
    }.get(parts[0], "other")

WIKILINK_RE  = re.compile(r"\[\[([^\]|#]+)(?:#[^\]|]*)?(?:\|[^\]]+)?\]\]")
MDLINK_RE    = re.compile(r"\[[^\]]+\]\(\.{0,2}/?([^)#?]+)(?:#[^)]*)?\)")
FRONTMATTER  = re.compile(r"^---\n(.*?)\n---", re.DOTALL)
TITLE_RE     = re.compile(r'^title:\s*"?([^"\n]+?)"?\s*$', re.MULTILINE)
SRCCOUNT_RE  = re.compile(r"^source_count:\s*(\d+)", re.MULTILINE)
STATUS_RE    = re.compile(r"^status:\s*(\w+)", re.MULTILINE)

# Pass 1: register every page as a node
for md in wiki_dir.rglob("*.md"):
    if md.name in ("index.md", "log.md"):
        continue
    rel = md.relative_to(wiki_dir)
    slug = md.stem
    text = md.read_text(encoding="utf-8", errors="ignore")
    fm_match = FRONTMATTER.match(text)
    title = slug
    source_count = 1
    status = "current"
    if fm_match:
        fm = fm_match.group(1)
        if (m := TITLE_RE.search(fm)): title = m.group(1).strip()
        if (m := SRCCOUNT_RE.search(fm)): source_count = int(m.group(1))
        if (m := STATUS_RE.search(fm)): status = m.group(1).strip()
    nodes[slug] = {
        "id": slug,
        "title": title,
        "type": page_type(rel),
        "path": str(md),
        "source_count": source_count,
        "status": status,
    }

# Pass 2: extract links
for md in wiki_dir.rglob("*.md"):
    if md.name in ("index.md", "log.md"):
        continue
    src = md.stem
    if src not in nodes:
        continue
    text = md.read_text(encoding="utf-8", errors="ignore")
    # frontmatter doesn't carry body links worth graphing — skip it
    body = FRONTMATTER.sub("", text, count=1)
    targets = set()
    for m in WIKILINK_RE.finditer(body):
        t = m.group(1).strip()
        # wikilink target is a title or slug; normalize to slug
        slug = t.lower().replace(" ", "-")
        targets.add(slug if slug in nodes else t)
    for m in MDLINK_RE.finditer(body):
        href = m.group(1).strip()
        if not href.endswith(".md"):
            continue
        targets.add(Path(href).stem)
    for tgt in targets:
        if tgt == src:
            continue
        if tgt in nodes:
            links.append({"source": src, "target": tgt})

out_path.parent.mkdir(parents=True, exist_ok=True)
out_path.write_text(
    "// auto-generated by build-graph.sh\n"
    "const GRAPH = " + json.dumps({"nodes": list(nodes.values()), "links": links}, indent=2) + ";\n",
    encoding="utf-8",
)
print(f"Wrote {out_path}: {len(nodes)} nodes, {len(links)} links")
PY
