#!/bin/bash
# stats.sh — Wiki health statistics
# Usage: ./tools/stats.sh
# Generated by WikiForge for {{config.project.name}}

set -euo pipefail

WIKI_DIR="wiki/"

if ! [ -d "$WIKI_DIR" ]; then
    echo "Error: wiki/ directory not found."
    exit 1
fi

echo "=== Wiki Stats: {{config.project.name}} ==="
echo ""

# Count pages by category
TOTAL=$(find "$WIKI_DIR" -name "*.md" -type f | wc -l | tr -d ' ')
ENTITIES=$(grep -rl "^type: entity" "$WIKI_DIR" 2>/dev/null | wc -l | tr -d ' ')
CONCEPTS=$(grep -rl "^type: concept" "$WIKI_DIR" 2>/dev/null | wc -l | tr -d ' ')
SOURCES=$(grep -rl "^type: source" "$WIKI_DIR" 2>/dev/null | wc -l | tr -d ' ')
COMPARISONS=$(grep -rl "^type: comparison" "$WIKI_DIR" 2>/dev/null | wc -l | tr -d ' ')

echo "Pages by category:"
echo "  Total:       $TOTAL"
echo "  Entities:    $ENTITIES"
echo "  Concepts:    $CONCEPTS"
echo "  Sources:     $SOURCES"
echo "  Comparisons: $COMPARISONS"
echo ""

# Recent log entries
LOG_FILE="wiki/log.md"
if [ -f "$LOG_FILE" ]; then
    echo "Recent log entries (last 5):"
    grep "^## \[" "$LOG_FILE" | tail -5 | while read -r line; do
        echo "  $line"
    done
    echo ""
else
    echo "No log file found at $LOG_FILE"
    echo ""
fi

# Orphan pages (pages not referenced in index.md)
INDEX_FILE="wiki/index.md"
if [ -f "$INDEX_FILE" ]; then
    echo "Orphan pages (not listed in index.md):"
    ORPHAN_COUNT=0
    for page in "$WIKI_DIR"*.md; do
        [ -f "$page" ] || continue
        basename=$(basename "$page" .md)
        # Skip index, log, and overview
        if [[ "$basename" == "index" || "$basename" == "log" || "$basename" == "overview" ]]; then
            continue
        fi
        if ! grep -q "$basename" "$INDEX_FILE" 2>/dev/null; then
            echo "  - $page"
            ORPHAN_COUNT=$((ORPHAN_COUNT + 1))
        fi
    done
    if [ "$ORPHAN_COUNT" -eq 0 ]; then
        echo "  (none)"
    fi
else
    echo "No index file found at $INDEX_FILE"
fi
echo ""
echo "=== End Stats ==="
