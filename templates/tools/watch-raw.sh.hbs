#!/bin/bash
# watch-raw.sh — watch raw/ for new files and announce them so an agent
# session (or an external script) can pick up the ingest.
# Usage: ./tools/watch-raw.sh [--exec <command>]
#
# Default behavior: print one line per new file ("RAW_ADDED <path>") to stdout.
# With --exec, runs the given command for each new file, with the path appended.
# Example: ./tools/watch-raw.sh --exec "echo Ingesting"
#
# Why: powers `ingestion_style: autonomous` by giving agents an event source
# for files dropped into raw/. The script itself is intentionally minimal —
# it announces; the agent (or an external runner) decides what to do.
#
# Generated by WikiForge for {{config.project.name}}

set -euo pipefail

EXEC_CMD=""
if [ "${1:-}" = "--exec" ]; then
    EXEC_CMD="${2:?--exec requires a command}"
    shift 2
fi

if ! [ -d "raw" ]; then
    echo "Error: raw/ not found. Run from the project root."
    exit 1
fi

# Prefer fswatch (cross-platform) > inotifywait (Linux) > polling (portable)
announce() {
    local path="$1"
    # Skip the assets directory — those are downloaded by the LLM during ingest,
    # they are not user-provided sources.
    case "$path" in
        */raw/assets/*) return ;;
    esac
    if [ -n "$EXEC_CMD" ]; then
        echo "RAW_ADDED $path"
        eval "$EXEC_CMD \"$path\""
    else
        echo "RAW_ADDED $path"
    fi
}

if command -v fswatch &>/dev/null; then
    echo "Watching raw/ via fswatch. Drop files to trigger announcements. Ctrl-C to stop."
    fswatch -0 -e "/assets/" raw/ | while IFS= read -r -d '' path; do
        [ -f "$path" ] && announce "$path"
    done
elif command -v inotifywait &>/dev/null; then
    echo "Watching raw/ via inotifywait. Drop files to trigger announcements. Ctrl-C to stop."
    inotifywait -mr -e create -e moved_to --format '%w%f' raw/ | while IFS= read -r path; do
        [ -f "$path" ] && announce "$path"
    done
else
    echo "fswatch and inotifywait not available — falling back to polling every 5s."
    # Track seen files in a tmp file
    seen=$(mktemp)
    trap 'rm -f "$seen"' EXIT
    find raw -type f -not -path "raw/assets/*" > "$seen"
    while true; do
        sleep 5
        current=$(mktemp)
        find raw -type f -not -path "raw/assets/*" > "$current"
        diff "$seen" "$current" | grep '^>' | sed 's/^> //' | while IFS= read -r path; do
            announce "$path"
        done
        mv "$current" "$seen"
    done
fi
