#!/usr/bin/env python3
"""pdf-to-md.py — Convert PDF to markdown with frontmatter.

Usage: python tools/pdf-to-md.py <input.pdf> [--output <output.md>]

Generated by WikiForge for {{config.project.name}}
"""

import argparse
import hashlib
import os
import sys
from datetime import datetime, timezone


def check_dependencies():
    try:
        import pymupdf4llm  # noqa: F401
    except ImportError:
        print("Error: pymupdf4llm is not installed.")
        print("Install it with: pip install pymupdf4llm")
        sys.exit(1)


def compute_hash(filepath: str) -> str:
    """Compute SHA-256 hash of a file."""
    sha256 = hashlib.sha256()
    with open(filepath, "rb") as f:
        for chunk in iter(lambda: f.read(8192), b""):
            sha256.update(chunk)
    return sha256.hexdigest()[:16]


def pdf_to_markdown(input_path: str, output_path: str | None = None) -> str:
    """Convert a PDF file to markdown with YAML frontmatter."""
    import pymupdf4llm

    if not os.path.isfile(input_path):
        print(f"Error: File not found: {input_path}")
        sys.exit(1)

    basename = os.path.splitext(os.path.basename(input_path))[0]
    content_hash = compute_hash(input_path)
    now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

    # Convert PDF to markdown
    print(f"Converting: {input_path}")
    md_text = pymupdf4llm.to_markdown(input_path)

    # Build frontmatter
    frontmatter = f"""---
type: source
title: "{basename}"
author: ""
date: ""
url: ""
source_type: "pdf"
content_hash: "{content_hash}"
ingested_at: "{now}"
status: "raw"
---

"""

    full_content = frontmatter + md_text

    # Determine output path
    if output_path is None:
        os.makedirs("raw/papers", exist_ok=True)
        output_path = os.path.join("raw", "papers", f"{basename}.md")

    with open(output_path, "w", encoding="utf-8") as f:
        f.write(full_content)

    print(f"Saved to: {output_path}")
    print(f"Content hash: {content_hash}")
    return output_path


def main():
    parser = argparse.ArgumentParser(
        description="Convert PDF to markdown with frontmatter"
    )
    parser.add_argument("input", help="Path to the input PDF file")
    parser.add_argument(
        "--output", "-o", help="Output markdown file path (default: raw/papers/<name>.md)"
    )
    args = parser.parse_args()

    check_dependencies()
    pdf_to_markdown(args.input, args.output)


if __name__ == "__main__":
    main()
