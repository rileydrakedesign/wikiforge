#!/bin/bash
# diff-wiki.sh — summarize what changed in wiki/ since a reference point
# Usage:
#   ./tools/diff-wiki.sh                  # diff since last ingest log entry
#   ./tools/diff-wiki.sh --since <ref>    # git ref (commit, tag, ISO date)
#   ./tools/diff-wiki.sh --days 7         # last N days
#
# Output: counts of pages added/modified by category, plus a tail of the
# log entries from the same window. Useful before kicking off a digest.
#
# Generated by WikiForge for {{config.project.name}}

set -euo pipefail

REF=""
DAYS=""

while [ $# -gt 0 ]; do
    case "$1" in
        --since) REF="${2:?--since requires a ref}"; shift 2 ;;
        --days)  DAYS="${2:?--days requires a number}"; shift 2 ;;
        *) echo "Unknown arg: $1"; exit 1 ;;
    esac
done

if ! [ -d "wiki" ]; then
    echo "Error: wiki/ not found. Run from the project root."
    exit 1
fi

# Resolve the reference
if [ -n "$DAYS" ]; then
    REF="$(date -u -d "${DAYS} days ago" +%Y-%m-%d 2>/dev/null || date -u -v "-${DAYS}d" +%Y-%m-%d)"
elif [ -z "$REF" ]; then
    # Last ingest entry from log
    if [ -f "wiki/log.md" ]; then
        REF=$(grep -oE '^\## \[[0-9-]+T[0-9:Z.+-]+\] ingest' wiki/log.md | tail -1 | grep -oE '[0-9-]+' | head -1 || true)
    fi
    if [ -z "$REF" ]; then
        echo "No reference point found. Pass --since <ref> or --days <N>."
        exit 1
    fi
fi

echo "=== Wiki diff since: ${REF} ==="
echo ""

# Use git if available — gives the cleanest diff
if git rev-parse --is-inside-work-tree &>/dev/null; then
    # Try as a ref first; if that fails, treat as a date
    if git rev-parse "$REF" &>/dev/null; then
        BASE="$REF"
    else
        BASE=$(git log --since="$REF" --reverse --format=%H -- wiki/ | head -1)
        if [ -z "$BASE" ]; then
            echo "No git activity in wiki/ since $REF."
            exit 0
        fi
        BASE="${BASE}^"
    fi
    echo "## Changed files"
    git diff --name-status "$BASE"..HEAD -- wiki/ | sed 's/^/  /'
    echo ""
    echo "## Counts by category"
    for cat in entities concepts sources comparisons; do
        added=$(git diff --name-only --diff-filter=A "$BASE"..HEAD -- "wiki/${cat}/" 2>/dev/null | wc -l | tr -d ' ')
        mod=$(git diff --name-only --diff-filter=M "$BASE"..HEAD -- "wiki/${cat}/" 2>/dev/null | wc -l | tr -d ' ')
        echo "  ${cat}: +${added} added, ~${mod} modified"
    done
else
    # No git — fall back to filesystem mtimes
    echo "## Files modified since $REF (no git available)"
    find wiki -name "*.md" -newermt "$REF" -not -name "log.md" 2>/dev/null \
        | sed 's/^/  /' || echo "  (none)"
fi

echo ""
echo "## Log entries in window"
if [ -f "wiki/log.md" ]; then
    # Walk entries chronologically, pick those at or after $REF
    awk -v ref="$REF" '
        /^## \[/ {
            match($0, /\[([^]]+)\]/, m)
            ts = m[1]
            keep = (ts >= ref)
        }
        keep { print }
    ' wiki/log.md | sed 's/^/  /' || echo "  (no log entries)"
else
    echo "  (no log)"
fi
