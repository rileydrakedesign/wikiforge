#!/bin/bash
# download-assets.sh — Download remote images and media referenced in raw/ to local assets
# Usage: ./tools/download-assets.sh [file-or-dir]
#   No argument: scan all of raw/
#   File:        scan that file only
#   Directory:   scan that directory recursively
#
# Why: URLs break over time, but local copies don't. Karpathy's LLM Wiki spec
# specifically calls this out — LLMs read text first, then can view local images
# in a second pass for additional context.
#
# Generated by WikiForge for {{config.project.name}}

set -euo pipefail

TARGET="${1:-raw/}"
ASSETS_DIR="raw/assets"

mkdir -p "$ASSETS_DIR"

if ! command -v curl &>/dev/null; then
    echo "Error: curl is required but not installed."
    exit 1
fi

# Find candidate markdown files
if [ -f "$TARGET" ]; then
    FILES=("$TARGET")
elif [ -d "$TARGET" ]; then
    mapfile -t FILES < <(find "$TARGET" -type f -name "*.md" -not -path "*/assets/*")
else
    echo "Error: '$TARGET' is not a file or directory."
    exit 1
fi

downloaded=0
skipped=0
failed=0

for file in "${FILES[@]}"; do
    # Extract remote image refs: ![alt](http...) or <img src="http...">
    urls=$(grep -oE '!\[[^]]*\]\(https?://[^)]+\)|<img[^>]+src="https?://[^"]+"' "$file" \
           | grep -oE 'https?://[^)"]+' || true)

    [ -z "$urls" ] && continue

    echo "Scanning: $file"

    while IFS= read -r url; do
        [ -z "$url" ] && continue

        # Derive a stable local filename from the URL
        ext="${url##*.}"
        case "$ext" in
            jpg|jpeg|png|gif|webp|svg|pdf) ;;
            *) ext="bin" ;;
        esac
        # Hash the URL to dedup across files
        hash=$(echo -n "$url" | sha256sum | cut -c1-12)
        local_name="${hash}.${ext}"
        local_path="${ASSETS_DIR}/${local_name}"

        if [ -f "$local_path" ]; then
            skipped=$((skipped + 1))
        else
            if curl -fsSL --max-time 30 -o "$local_path" "$url" 2>/dev/null; then
                echo "  ↓ $url -> $local_path"
                downloaded=$((downloaded + 1))
            else
                echo "  ✗ FAILED: $url"
                failed=$((failed + 1))
                rm -f "$local_path"
                continue
            fi
        fi

        # Rewrite the reference in the file to point at the local copy
        # Use a portable in-place sed (BSD and GNU)
        escaped_url=$(printf '%s\n' "$url" | sed 's/[\/&]/\\&/g')
        sed -i.bak "s|${escaped_url}|${local_path}|g" "$file" && rm -f "${file}.bak"
    done <<< "$urls"
done

echo ""
echo "Done. Downloaded: ${downloaded}, already-local: ${skipped}, failed: ${failed}"
echo "Assets directory: ${ASSETS_DIR}"
