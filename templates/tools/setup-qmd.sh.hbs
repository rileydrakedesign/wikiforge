#!/bin/bash
# setup-qmd.sh — Initialize qmd for semantic search
# Usage: ./tools/setup-qmd.sh
# Generated by WikiForge for {{config.project.name}}

set -euo pipefail

# Check that qmd is installed
if ! command -v qmd &>/dev/null; then
    echo "Error: qmd is not installed."
    echo "Install it with: pip install qmd"
    exit 1
fi

echo "=== Setting up qmd for {{config.project.name}} ==="
echo ""

# Register wiki/ as a collection
echo "Registering wiki/ collection..."
qmd collection add wiki/ --name "{{config.project.name}}-wiki" --type markdown
echo "  Done."

# Register raw/ as a collection
if [ -d "raw/" ]; then
    echo "Registering raw/ collection..."
    qmd collection add raw/ --name "{{config.project.name}}-raw" --type markdown
    echo "  Done."
else
    echo "Skipping raw/ (directory not found)."
fi

# Add project context
echo ""
echo "Adding project context..."
qmd context set project.name "{{config.project.name}}"
qmd context set project.domain "{{config.project.domain}}"
{{#if config.project.description}}
qmd context set project.description "{{config.project.description}}"
{{/if}}
echo "  Done."

# Run initial indexing
echo ""
echo "Running initial index..."
qmd index --collection "{{config.project.name}}-wiki"
if [ -d "raw/" ]; then
    qmd index --collection "{{config.project.name}}-raw"
fi
echo "  Done."

# Generate embeddings
echo ""
echo "Generating embeddings..."
qmd embed --collection "{{config.project.name}}-wiki"
if [ -d "raw/" ]; then
    qmd embed --collection "{{config.project.name}}-raw"
fi
echo "  Done."

echo ""
echo "=== qmd setup complete ==="
echo "Search with: qmd search \"your query\""
