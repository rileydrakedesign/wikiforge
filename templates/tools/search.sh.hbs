#!/bin/bash
# search.sh — Search the wiki for matching content
# Usage: ./tools/search.sh <query> [directory]
# Generated by WikiForge for {{config.project.name}}

set -euo pipefail

QUERY="${1:?Usage: ./tools/search.sh <query> [directory]}"
SEARCH_DIR="${2:-wiki/}"

if ! [ -d "$SEARCH_DIR" ]; then
    echo "Error: Directory '$SEARCH_DIR' does not exist."
    exit 1
fi

# Use ripgrep if available, fall back to grep
if command -v rg &>/dev/null; then
    echo "=== Search results for: $QUERY ==="
    echo ""
    rg --type md \
       --ignore-case \
       --line-number \
       --context 2 \
       --heading \
       --color never \
       "$QUERY" "$SEARCH_DIR" || echo "No results found."
else
    echo "=== Search results for: $QUERY ==="
    echo "(Using grep — install ripgrep for better results)"
    echo ""
    grep -r -i -n \
         --include="*.md" \
         -C 2 \
         "$QUERY" "$SEARCH_DIR" || echo "No results found."
fi
