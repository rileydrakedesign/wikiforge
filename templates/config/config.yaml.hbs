# WikiForge Runtime Configuration
# Agents and skills reference these variables via {variable_name} syntax.

project_name: "{{config.project.name}}"
project_domain: "{{config.project.domain}}"
project_description: "{{config.project.description}}"
user_name: ""                          # Set this to your name
wiki_root: "wiki"
raw_root: "raw"
output_root: "outputs"
forge_root: ".forge"
citation_format: "{{config.wiki.citation_format}}"
cross_ref_style: "{{config.wiki.cross_ref_style}}"
organization: "{{config.knowledge.organization}}"
ingestion_style: "{{config.workflows.ingestion_style}}"
scale: "{{config.knowledge.scale}}"
frontmatter_enabled: {{config.wiki.frontmatter}}
source_types:
{{#each config.knowledge.source_types}}
  - "{{this}}"
{{/each}}
log_file: "wiki/log.md"
index_file: "wiki/index.md"
overview_file: "wiki/overview.md"

# Lifecycle thresholds — used by decay-and-verify and lint to decide when
# claims are aging. These default by scale and can be overridden here.
decay_threshold_days: {{#if (eq config.knowledge.scale "small")}}180{{else if (eq config.knowledge.scale "medium")}}90{{else}}60{{/if}}

# Lint posture — auto-fix safe categories by default; users override with
# `--report-only` when invoking the skill, or by setting this to false.
lint_autofix: true

# Maturity thresholds — gate autonomous behavior on wiki state. Below
# these counts, autonomous-mode agents fall back to asking the user for
# direction instead of acting unsupervised.
maturity:
  research_sources_min: {{config.maturity.research_sources_min}}
  review_pages_min: {{config.maturity.review_pages_min}}
  synthesis_pages_min: {{config.maturity.synthesis_pages_min}}
